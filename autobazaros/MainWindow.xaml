<Window x:Class="autobazaros.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autobazar"
        Height="600"
        Width="1100"
        Background="#EEF2F7"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Moderní tlačítko -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14 8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Moderní DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition/>
            <RowDefinition Height="90"/>
        </Grid.RowDefinitions>

        <!-- Horní header -->
        <Border Background="#1E293B">
            <Grid Margin="30 0">
                <TextBlock Text="Autobazar Management"
                           Foreground="White"
                           FontSize="24"
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Hlavní karta -->
        <Border Grid.Row="1"
                Background="White"
                Margin="30"
                CornerRadius="20"
                Padding="25">

            <ListBox x:Name="CarsGrid"
         Background="Transparent"
         BorderThickness="0"
         SelectionMode="Single"
         ScrollViewer.VerticalScrollBarVisibility="Auto">

                <ListBox.ItemTemplate>
                    <DataTemplate>

                        <Border Background="White"
                    CornerRadius="15"
                    Padding="20"
                    Margin="0 0 0 15">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ikona -->
                                <TextBlock Text="🚗"
                               FontSize="32"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                                <!-- Info -->
                                <StackPanel Grid.Column="1"
                                Margin="15 0">

                                    <TextBlock Text="{Binding Znacka}"
                                   FontSize="16"
                                   FontWeight="Bold"/>

                                    <TextBlock Text="{Binding Model}"
                                   FontSize="14"
                                   Foreground="#64748B"/>

                                    <TextBlock>
                            <Run Text="Majitel: "/>
                            <Run Text="{Binding Jmeno}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding Prijmeni}"/>
                                    </TextBlock>

                                </StackPanel>

                                <!-- SPZ + Rok -->
                                <StackPanel Grid.Column="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">

                                    <Border Background="#2563EB"
                                CornerRadius="8"
                                Padding="8 4"
                                Margin="0 0 0 5">

                                        <TextBlock Text="{Binding SPZ}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="{Binding RokVyroby}"
                                   Foreground="#475569"
                                   HorizontalAlignment="Right"/>

                                </StackPanel>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>

        </Border>

        <!-- Spodní panel -->
        <Grid Grid.Row="2" Margin="30 0 30 20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">

                <Button Content="Přidat"
                        Background="#22C55E"
                        Margin="5"
                        Click="Add_Click" Width="59"/>

                <Button Content="Upravit"
                        Background="#F59E0B"
                        Margin="5"
                        Click="Edit_Click" Width="59"/>

                <Button Content="Smazat"
                        Background="#EF4444"
                        Margin="5"
                        Click="Delete_Click" Width="59"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>