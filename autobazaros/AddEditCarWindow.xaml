<Window x:Class="autobazaros.AddEditCarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detail auta"
        Height="720"
        Width="550"
        Background="#EEF2F7"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="0 5 0 15"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334155"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#2563EB"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <ScrollViewer>
        <StackPanel Margin="30">

            <!-- ===== SEKCE MAJITEL ===== -->
            <Border Background="White"
                    CornerRadius="20"
                    Padding="25"
                    Margin="0 0 0 25">

                <StackPanel>

                    <TextBlock Text="👤 Informace o majiteli"
                               FontSize="18"
                               Margin="0 0 0 20"
                               FontWeight="Bold"/>

                    <TextBlock Text="Jméno"/>
                    <TextBox x:Name="JmenoBox"/>

                    <TextBlock Text="Příjmení"/>
                    <TextBox x:Name="PrijmeniBox"/>

                    <TextBlock Text="Adresa bydliště"/>
                    <TextBox x:Name="AdresaBox"/>

                </StackPanel>
            </Border>

            <!-- ===== SEKCE AUTO ===== -->
            <Border Background="White"
                    CornerRadius="20"
                    Padding="25"
                    Margin="0 0 0 25">

                <StackPanel>

                    <TextBlock Text="🚗 Informace o autě"
                               FontSize="18"
                               Margin="0 0 0 20"
                               FontWeight="Bold"/>

                    <TextBlock Text="Značka auta"/>
                    <TextBox x:Name="ZnackaBox"/>

                    <TextBlock Text="Model auta"/>
                    <TextBox x:Name="ModelBox"/>

                    <TextBlock Text="SPZ"/>
                    <TextBox x:Name="SPZBox"/>

                    <TextBlock Text="Najeto km"/>
                    <TextBox x:Name="NajetoBox"/>

                    <TextBlock Text="Barva"/>
                    <TextBox x:Name="BarvaBox"/>

                    <TextBlock Text="Typ motoru"/>
                    <TextBox x:Name="MotorBox"/>

                    <TextBlock Text="Rok výroby"/>
                    <TextBox x:Name="RokBox"/>

                </StackPanel>
            </Border>

            <!-- TLAČÍTKO -->
            <Button Content="💾 Uložit změny"
                    Click="Save_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>